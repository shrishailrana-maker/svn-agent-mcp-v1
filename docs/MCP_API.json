    {
      "name": "svn_diff",
      "description": "Return a bounded scoped diff and per-file counts.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "cwd": {
            "description": "Absolute WC directory; required for relative paths.",
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "pattern": "^[^\\x00]*$"
          },
          "paths": {
            "minItems": 1,
            "maxItems": 500,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096,
              "pattern": "^[^\\x00]*$"
            },
            "description": "Explicit paths inside one WC."
          },
          "ignoreEol": {
            "type": "boolean"
          },
          "lineLimit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 2000
          },
          "diffMode": {
            "type": "string",
            "enum": [
              "summary",
              "compact",
              "full"
            ]
          },
          "maxChars": {
            "type": "integer",
            "minimum": 256,
            "maximum": 64000
          },
          "maxHunksPerFile": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "maxFiles": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500
          },
          "fileCursor": {
            "type": "string",
            "maxLength": 32,
            "pattern": "^\\d+$"
          },
          "cursor": {
            "type": "string",
            "maxLength": 32,
            "pattern": "^\\d+$"
          },
          "revision": {
            "type": "string",
            "maxLength": 257,
            "pattern": "^(?:\\d+|HEAD|BASE|COMMITTED|PREV|\\{[^}\\r\\n\\x00]+\\})(?::(?:\\d+|HEAD|BASE|COMMITTED|PREV|\\{[^}\\r\\n\\x00]+\\}))?$"
          },
          "responseMode": {
            "type": "string",
            "enum": [
              "compact",
              "standard",
              "full"
            ]
          }
        },
        "required": [
          "paths"
        ],
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
