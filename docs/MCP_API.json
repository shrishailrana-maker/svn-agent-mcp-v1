            "minLength": 1,
            "maxLength": 4096,
            "pattern": "^[^\\x00]*$"
          },
          "detailed": {
            "type": "boolean"
          },
          "responseMode": {
            "type": "string",
            "enum": [
              "compact",
              "standard",
              "full"
            ]
          }
        },
        "$schema": "http://json-schema.org/draft-07/schema#"
      },
      "execution": {
        "taskSupport": "forbidden"
      }
    },
