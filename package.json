{
  "name": "svn-agent-mcp",
  "version": "1.2.0",
  "description": "Strict SVN Model Context Protocol server for agent-safe SVN workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shrishailrana-maker/svn-agent-mcp-v1.git"
  },
  "bugs": {
    "url": "https://github.com/shrishailrana-maker/svn-agent-mcp-v1/issues"
  },
  "homepage": "https://github.com/shrishailrana-maker/svn-agent-mcp-v1#readme",
  "bin": {
    "svn-agent-mcp": "dist/index.js"
  },
  "files": [
    "bin/",
    "dist/",
    "third_party_licenses/",
    "docs/SPEC.md",
    "docs/MCP_API.json",
    "CHANGELOG.md",
    "README.md",
    "SECURITY.md",
    "THIRD_PARTY_CHECKSUMS.txt",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "check:runtime": "node scripts/check-runtime.mjs",
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "generate:api-contract": "node scripts/generate-api-contract.mjs",
    "check:api-contract": "node scripts/generate-api-contract.mjs --check",
    "prepack": "npm run build && npm run generate:api-contract",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --passWithNoTests",
    "test:client": "node scripts/smoke-mcp-client.mjs",
    "test:package": "node scripts/smoke-packed-install.mjs",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "benchmark:responses": "node scripts/benchmark-responses.mjs",
    "prepare:local": "npm run build && npm run generate:api-contract && npm run release:prepare",
    "release:prepare": "node scripts/prepare-release.mjs",
    "clean": "node scripts/clean.mjs"
  },
  "keywords": [
    "mcp",
    "svn",
    "subversion",
    "model-context-protocol"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=11.16.0"
  },
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "overrides": {
    "@hono/node-server": "^2.0.5"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "unrs-resolver@1.12.2": true
  }
}
